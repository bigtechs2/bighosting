generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==============================
// 1. USERS
// ==============================
model User {
  id                    String          @id @default(cuid())
  email                 String          @unique @db.VarChar(191)
  password              String          @db.Text
  name                  String          @db.VarChar(100)
  role                  Role            @default(USER)
  pterodactylUserId     Int?            @unique
  pterodactylEmail      String?         @db.VarChar(191)
  isSuspended           Boolean         @default(false)
  suspensionReason      String?         @db.Text
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  lastLogin             DateTime?

  orders                Order[]
  payments              Payment[]
  servers               Server[]
  tickets               Ticket[]
  notifications         Notification[]
  invoices              Invoice[]
  auditLogs             AuditLog[]
  announcements         Announcement[]   @relation("AdminAnnouncements")
  passwordResets        PasswordReset[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

// ==============================
// 2. PLANS
// ==============================
model Plan {
  id              String   @id @default(cuid())
  name            String   @db.VarChar(100)
  description     String?  @db.Text
  priceMonthly    Int      @default(1500)
  priceYearly     Int      @default(15000)
  currency        String   @default("TSh") @db.VarChar(10)
  cpuLimit        Int      @default(100)
  ramLimit        Int      @default(512)
  diskLimit       Int      @default(1024)
  botSizeLimit    Int      @default(1)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders          Order[]
  servers         Server[]

  @@map("plans")
}

// ==============================
// 3. ORDERS
// ==============================
model Order {
  id            String       @id @default(cuid())
  orderNumber   String       @unique @db.VarChar(50)
  userId        String
  planId        String
  quantity      Int          @default(1)
  totalAmount   Int
  currency      String       @default("TSh") @db.VarChar(10)
  status        OrderStatus  @default(PENDING)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user          User         @relation(fields: [userId], references: [id])
  plan          Plan         @relation(fields: [planId], references: [id])
  payments      Payment[]
  servers       Server[]
  invoices      Invoice[]

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  EXPIRED
}

// ==============================
// 4. PAYMENTS
// ==============================
model Payment {
  id              String          @id @default(cuid())
  transactionId   String?         @unique @db.VarChar(100)
  userId          String
  orderId         String
  amount          Int
  currency        String          @default("TSh") @db.VarChar(10)
  gateway         PaymentGateway  @default(STRIPE)
  status          PaymentStatus   @default(PENDING)
  metadata        Json?
  receiptUrl      String?         @db.Text
  paidAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id])
  order           Order           @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@map("payments")
}

enum PaymentGateway {
  STRIPE
  PESAPAL
  MOMO
  BANK
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  REFUNDED
}

// ==============================
// 5. SERVERS
// ==============================
model Server {
  id                  String          @id @default(cuid())
  serverIdentifier    String          @unique @db.VarChar(100)
  userId              String
  orderId             String
  planId              String
  name                String          @db.VarChar(100)
  description         String?         @db.Text
  node                String?         @db.VarChar(50)
  nestId              Int
  eggId               Int
  allocationId        Int?
  port                Int?
  status              ServerStatus    @default(PENDING)
  pterodactylUserId   Int
  cpuLimit            Int
  ramLimit            Int
  diskLimit           Int
  databaseLimit       Int
  backupLimit         Int
  features            Json            @default("[]")
  startupVariables    Json            @default("{}")
  suspended           Boolean         @default(false)
  suspensionReason    String?         @db.Text
  expiresAt           DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  user                User            @relation(fields: [userId], references: [id])
  order               Order           @relation(fields: [orderId], references: [id])
  plan                Plan            @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([serverIdentifier])
  @@map("servers")
}

enum ServerStatus {
  PENDING
  INSTALLING
  RUNNING
  STOPPED
  RESTARTING
  SUSPENDED
  FAILED
  DELETED
}

// ==============================
// 6. TICKETS
// ==============================
model Ticket {
  id          String          @id @default(cuid())
  ticketNumber String         @unique @db.VarChar(50)
  userId      String
  subject     String          @db.VarChar(200)
  message     String          @db.Text
  status      TicketStatus    @default(OPEN)
  priority    TicketPriority  @default(MEDIUM)
  category    String?         @db.VarChar(50)
  resolvedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("tickets")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ==============================
// 7. NOTIFICATIONS
// ==============================
model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String   @db.VarChar(100)
  message   String   @db.Text
  type      String   @db.VarChar(50)
  link      String?  @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// ==============================
// 8. INVOICES
// ==============================
model Invoice {
  id            String          @id @default(cuid())
  invoiceNumber String          @unique @db.VarChar(50)
  userId        String
  orderId       String?
  amount        Int
  currency      String          @default("TSh") @db.VarChar(10)
  status        InvoiceStatus   @default(UNPAID)
  dueDate       DateTime
  paidAt        DateTime?
  pdfUrl        String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user          User            @relation(fields: [userId], references: [id])
  order         Order?          @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  UNPAID
  PAID
  OVERDUE
  CANCELLED
}

// ==============================
// 9. COUPONS
// ==============================
model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique @db.VarChar(50)
  description    String?   @db.Text
  discountType   DiscountType @default(PERCENTAGE)
  discountValue  Float
  minAmount      Float?
  maxUses        Int?
  usedCount      Int       @default(0)
  validFrom      DateTime
  validUntil     DateTime
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("coupons")
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ==============================
// 10. ANNOUNCEMENTS
// ==============================
model Announcement {
  id        String   @id @default(cuid())
  title     String   @db.VarChar(200)
  content   String   @db.Text
  type      String   @db.VarChar(50)
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  createdBy String
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  admin     User     @relation("AdminAnnouncements", fields: [createdBy], references: [id])

  @@index([isActive])
  @@map("announcements")
}

// ==============================
// 11. SETTINGS
// ==============================
model Setting {
  id          String   @id @default(cuid())
  key         String   @unique @db.VarChar(100)
  value       Json
  description String?  @db.Text
  category    String?  @db.VarChar(50)
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

// ==============================
// 12. LOGS
// ==============================
model Log {
  id        String   @id @default(cuid())
  level     String   @db.VarChar(20)
  message   String   @db.Text
  meta      Json?
  source    String?  @db.VarChar(50)
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
  @@map("logs")
}

// ==============================
// 13. AUDIT LOGS
// ==============================
model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String   @db.VarChar(100)
  targetType  String   @db.VarChar(50)
  targetId    String   @db.VarChar(100)
  details     Json?
  ipAddress   String?  @db.VarChar(45)
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==============================
// 14. PASSWORD RESETS
// ==============================
model PasswordReset {
  id        String   @id @default(cuid())
  email     String   @db.VarChar(191)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [email], references: [email])

  @@index([email])
  @@index([token])
  @@index([expiresAt])
  @@map("password_resets")
}
