<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Set New Password – bighosting by bigmanjtech™</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🔐</text></svg>" />
  <style>
    .auth-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 100px 24px 60px;
      background: var(--bg-primary);
    }
    .auth-container { width: 100%; max-width: 440px; }
    .auth-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--radius);
      padding: 48px 40px;
      box-shadow: var(--shadow);
    }
    .auth-header { text-align: center; margin-bottom: 32px; }
    .auth-header .logo-icon { font-size: 3rem; display: block; margin-bottom: 8px; }
    .auth-header h1 { font-size: 1.8rem; font-weight: 700; color: var(--text-primary); }
    .auth-header p { color: var(--text-muted); font-size: 0.95rem; margin-top: 4px; }
    .auth-header .brand { color: var(--accent); }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; font-weight: 600; font-size: 0.9rem; color: var(--text-primary); margin-bottom: 6px; }
    .form-group input {
      width: 100%; padding: 14px 16px; background: var(--bg-elevated);
      border: 1px solid var(--border-color); border-radius: var(--radius-sm);
      color: var(--text-primary); font-size: 1rem; transition: border-color var(--transition); outline: none;
    }
    .form-group input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }
    .form-group .password-hint { font-size: 0.8rem; color: var(--text-muted); margin-top: 4px; }
    .form-group .password-hint.valid { color: var(--accent); }
    .form-group .password-hint.invalid { color: #f87171; }
    .btn-auth {
      width: 100%; padding: 14px; font-size: 1.05rem; font-weight: 700;
      background: var(--accent); color: var(--text-inverse); border: none;
      border-radius: var(--radius-sm); cursor: pointer; transition: all var(--transition);
    }
    .btn-auth:hover { background: var(--accent-hover); transform: translateY(-2px); box-shadow: 0 4px 20px var(--accent-glow); }
    .btn-auth:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    .auth-footer { text-align: center; margin-top: 24px; color: var(--text-muted); font-size: 0.95rem; }
    .auth-footer a { color: var(--accent); font-weight: 600; text-decoration: none; }
    .auth-footer a:hover { color: var(--accent-hover); text-decoration: underline; }
    .error-message {
      background: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.3);
      color: #f87171; padding: 12px 16px; border-radius: var(--radius-sm);
      margin-bottom: 16px; font-size: 0.9rem; display: none;
    }
    .error-message.show { display: block; }
    .success-message {
      background: rgba(16, 185, 129, 0.15); border: 1px solid rgba(16, 185, 129, 0.3);
      color: var(--accent); padding: 12px 16px; border-radius: var(--radius-sm);
      margin-bottom: 16px; font-size: 0.9rem; display: none;
    }
    .success-message.show { display: block; }
    .loader {
      display: inline-block; width: 20px; height: 20px;
      border: 3px solid var(--text-inverse); border-radius: 50%;
      border-top-color: transparent; animation: spin 0.8s linear infinite;
      vertical-align: middle; margin-right: 8px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .token-status {
      font-size: 0.85rem;
      padding: 12px 16px;
      border-radius: var(--radius-sm);
      margin-bottom: 16px;
      text-align: center;
    }
    .token-status.valid {
      background: rgba(16, 185, 129, 0.15);
      border: 1px solid rgba(16, 185, 129, 0.3);
      color: var(--accent);
    }
    .token-status.invalid {
      background: rgba(239, 68, 68, 0.15);
      border: 1px solid rgba(239, 68, 68, 0.3);
      color: #f87171;
    }
    @media (max-width: 480px) {
      .auth-card { padding: 32px 20px; }
      .auth-header h1 { font-size: 1.5rem; }
    }
  </style>
</head>
<body>

  <nav class="navbar">
    <div class="container nav-container">
      <a href="/" class="nav-logo">
        <span class="logo-icon">🚀</span>
        <span>bighosting</span>
        <span class="logo-badge">™</span>
      </a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/login.html" class="btn btn-outline">Login</a></li>
      </ul>
    </div>
  </nav>

  <section class="auth-page">
    <div class="auth-container">
      <div class="auth-card">
        <div class="auth-header">
          <span class="logo-icon">🔐</span>
          <h1>Set New Password</h1>
          <p>Create a strong password for your <span class="brand">bighosting</span> account</p>
        </div>

        <div class="token-status" id="tokenStatus">⏳ Validating token...</div>
        <div class="error-message" id="errorMessage"></div>
        <div class="success-message" id="successMessage"></div>

        <form id="resetForm" style="display: none;">
          <div class="form-group">
            <label for="password">New Password</label>
            <input 
              type="password" 
              id="password" 
              placeholder="Enter new password" 
              required 
              minlength="6"
              autocomplete="new-password"
            />
            <div class="password-hint" id="passwordHint">🔒 Min 6 characters</div>
          </div>
          <div class="form-group">
            <label for="confirmPassword">Confirm Password</label>
            <input 
              type="password" 
              id="confirmPassword" 
              placeholder="Confirm new password" 
              required 
              minlength="6"
              autocomplete="new-password"
            />
          </div>
          <button type="submit" class="btn-auth" id="resetBtn">Update Password</button>
        </form>

        <div class="auth-footer" id="footerLinks">
          <a href="/login.html">Back to Login</a>
        </div>

        <div class="auth-footer" style="margin-top: 12px; font-size: 0.8rem; color: var(--text-muted);">
          📞 Support: <strong style="color: var(--accent);">255636756591</strong>
        </div>
      </div>
    </div>
  </section>

  <script>
    (function() {
      // ---- Get token from URL ----
      const params = new URLSearchParams(window.location.search);
      const token = params.get('token');

      const form = document.getElementById('resetForm');
      const passwordInput = document.getElementById('password');
      const confirmInput = document.getElementById('confirmPassword');
      const resetBtn = document.getElementById('resetBtn');
      const errorMsg = document.getElementById('errorMessage');
      const successMsg = document.getElementById('successMessage');
      const passwordHint = document.getElementById('passwordHint');
      const tokenStatus = document.getElementById('tokenStatus');
      const footerLinks = document.getElementById('footerLinks');

      // ---- Validate Token ----
      async function validateToken() {
        if (!token) {
          tokenStatus.className = 'token-status invalid';
          tokenStatus.textContent = '❌ No reset token provided. Please request a new reset link.';
          footerLinks.innerHTML = '<a href="/forgot-password.html">Request New Reset Link</a>';
          return;
        }

        try {
          const response = await fetch(`/api/auth/validate-reset-token?token=${encodeURIComponent(token)}`);
          const data = await response.json();

          if (!response.ok) {
            throw new Error(data.message || 'Invalid or expired token.');
          }

          tokenStatus.className = 'token-status valid';
          tokenStatus.textContent = '✅ Token verified! Set your new password below.';
          form.style.display = 'block';

        } catch (error) {
          tokenStatus.className = 'token-status invalid';
          tokenStatus.textContent = `❌ ${error.message}`;
          footerLinks.innerHTML = '<a href="/forgot-password.html">Request New Reset Link</a>';
        }
      }

      validateToken();

      // ---- Password Strength ----
      passwordInput.addEventListener('input', () => {
        const len = passwordInput.value.length;
        if (len === 0) {
          passwordHint.textContent = '🔒 Min 6 characters';
          passwordHint.className = 'password-hint';
        } else if (len < 6) {
          passwordHint.textContent = '⚠️ Too short — min 6 characters';
          passwordHint.className = 'password-hint invalid';
        } else if (len < 10) {
          passwordHint.textContent = '👍 Good — add more characters for strength';
          passwordHint.className = 'password-hint valid';
        } else {
          passwordHint.textContent = '✅ Strong password!';
          passwordHint.className = 'password-hint valid';
        }
      });

      // ---- Hide messages on input ----
      passwordInput.addEventListener('input', () => {
        errorMsg.classList.remove('show');
        successMsg.classList.remove('show');
      });
      confirmInput.addEventListener('input', () => {
        errorMsg.classList.remove('show');
        successMsg.classList.remove('show');
      });

      // ---- Reset Password Submit ----
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorMsg.classList.remove('show');
        successMsg.classList.remove('show');

        const password = passwordInput.value.trim();
        const confirm = confirmInput.value.trim();

        if (!password || !confirm) {
          errorMsg.textContent = 'Please fill in both password fields.';
          errorMsg.classList.add('show');
          return;
        }

        if (password.length < 6) {
          errorMsg.textContent = 'Password must be at least 6 characters.';
          errorMsg.classList.add('show');
          return;
        }

        if (password !== confirm) {
          errorMsg.textContent = 'Passwords do not match.';
          errorMsg.classList.add('show');
          return;
        }

        resetBtn.disabled = true;
        resetBtn.innerHTML = '<span class="loader"></span> Updating...';

        try {
          const response = await fetch('/api/auth/reset-password', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ token, password }),
          });

          const data = await response.json();

          if (!response.ok) {
            throw new Error(data.message || 'Failed to reset password.');
          }

          successMsg.textContent = '✅ Password updated successfully! Redirecting to login...';
          successMsg.classList.add('show');
          resetBtn.textContent = '✓ Done!';
          resetBtn.disabled = true;

          setTimeout(() => {
            window.location.href = '/login.html';
          }, 3000);

        } catch (error) {
          errorMsg.textContent = error.message || 'Something went wrong. Please try again.';
          errorMsg.classList.add('show');
          resetBtn.disabled = false;
          resetBtn.textContent = 'Update Password';
        }
      });

    })();
  </script>

</body>
</html>