# ==========================================
# BIGHOSTING by bigmanjtech™ - Environment
# ==========================================

# ---- SERVER ----
PORT=5000
NODE_ENV=development
APP_URL="https://bighosting.onrender.com"

# ---- DATABASE (PlanetScale / MySQL) ----
DATABASE_URL="mysql://username:password@host:port/database?sslaccept=strict"

# ---- JWT AUTH ----
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="7d"

# ---- PTERODACTYL API ----
PTERODACTYL_PANEL_URL="https://your-pterodactyl-panel.com"
PTERODACTYL_API_KEY="your-application-api-key"
PTERODACTYL_CLIENT_API_KEY="your-client-api-key"
PTERODACTYL_DEFAULT_NEST=5
PTERODACTYL_DEFAULT_EGG=1
PTERODACTYL_DEFAULT_NODE=1

# ---- STRIPE (Payments) ----
STRIPE_SECRET_KEY="sk_live_your-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
STRIPE_PUBLISHABLE_KEY="pk_live_your-publishable-key"
STRIPE_CURRENCY="usd"

# ---- CURRENCY SETTINGS (Hybrid) ----
PRIMARY_CURRENCY="TSh"
SECONDARY_CURRENCY="USD"
EXCHANGE_RATE="2500"

# ---- BUSINESS CONTACT ----
BUSINESS_PHONE="255636756591"
BUSINESS_EMAIL="support@bighosting.com"

# ---- EMAIL (Resend) ----
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="noreply@bighosting.com"

# ---- ADMIN SEED ----
ADMIN_EMAIL="admin@bighosting.com"
ADMIN_PASSWORD="change-this-password-immediately"